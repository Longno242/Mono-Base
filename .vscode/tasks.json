{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup Dependencies",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/scripts/setup_deps.ps1"],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": ["-B", "build", "-G", "Visual Studio 18 2026", "-A", "x64"],
            "options": { "cwd": "${workspaceFolder}" },
            "dependsOn": ["Setup Dependencies"],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build Release",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "--config", "Release"],
            "options": { "cwd": "${workspaceFolder}" },
            "dependsOn": ["CMake: Configure"],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": "$msCompile"
        }
    ]
}
